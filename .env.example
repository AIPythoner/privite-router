# ===== MySQL =====
MYSQL_HOST=192.0.2.10
MYSQL_PORT=3306
MYSQL_USER=router_admin
MYSQL_PASSWORD=change_me
MYSQL_DATABASE=router_admin

# ===== Admin UI =====
# If ADMIN_PASSWORD is NOT set, a hardcoded default password is used
# (see DEFAULT_PASSWORD in src/auth.js). Login and change it immediately.
# Priority: runtime-changed (via UI) > ADMIN_PASSWORD env > hardcoded default
ADMIN_USER=admin
# ADMIN_PASSWORD=change_me_strong

# ===== Keep-alive (Render free tier sleeps after 15 min idle) =====
# Public URL of this service. If set, will self-ping /healthz every KEEPALIVE_INTERVAL_MS.
SELF_URL=https://your-app.onrender.com
KEEPALIVE_INTERVAL_MS=50000

# ===== Server =====
PORT=3000
